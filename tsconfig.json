{
    "compilerOptions": {
        "rootDir": "./src",
        "outDir": "./dist",
        "target": "ES2020",
        "declaration": true,
        "module": "nodenext",
        "noImplicitAny": false,
        "sourceMap": true,
        "moduleResolution": "nodenext",
        "resolveJsonModule": true,
        "allowSyntheticDefaultImports": true
    },
    "include": [
        "src/**/*"
    ],
    "exclude": [
        "node_modules"
    ]
}